<Window x:Class="File_manager.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:File_manager.View"
        Title="Asset Explorer" Height="760" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <local:ColWidthConverter x:Key="ColWidth"/>
        <local:ExtIconConverter x:Key="ExtIcon"/>

        <!-- Dark ContextMenu -->
        <Style x:Key="DarkMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="12,6">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#3E3E3E"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- ══════ SCROLLBAR (keyed, not global) ══ -->
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#555555" CornerRadius="3" Margin="2,1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VScrollBar" TargetType="ScrollBar">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#2D2D2D" CornerRadius="3" Width="10">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Height="0" Opacity="0" Background="Transparent" BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Height="0" Opacity="0" Background="Transparent" BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScroll" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource VScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════ BUTTONS ══ -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1177BB"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter Property="Background" Value="#094F7A"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#C72E2E"/>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3E3E3E"/>
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════ FILTER CHIP ══ -->
        <Style x:Key="FilterChip" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#3E3E3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="GroupName" Value="StatusFilter"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D2D"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#094F7A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════ TEXTBOX ══ -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="CaretBrush" Value="#007ACC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════ COMBOBOX ══ -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="26"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Margin="10,6" VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      TextBlock.Foreground="#CCCCCC"/>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#007ACC"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#252526" BorderBrush="#007ACC" BorderThickness="1"
                                        CornerRadius="4" MaxHeight="200"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <ToggleButton Background="Transparent" BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Focusable="False"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="Padding" Value="10,7"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#094F7A"/></Trigger>
                                    <Trigger Property="IsSelected"  Value="True"><Setter Property="Background" Value="#007ACC"/></Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- ══════ CHECKBOX ══ -->
        <Style x:Key="DarkCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="15" Height="15" CornerRadius="3"
                                    Background="#3C3C3C" BorderBrush="#555555" BorderThickness="1" Margin="0,0,7,0">
                                <TextBlock x:Name="Chk" Text="✓" Foreground="#007ACC"
                                           FontSize="10" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chk" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════ LIST ROW ══ -->
        <Style x:Key="FileRow" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="0,3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094F7A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════ TOPBAR ══ -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" Foreground="#007ACC" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Asset" Foreground="#CCCCCC" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="Explorer" Foreground="#777777" FontSize="15" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="1" Margin="18,9" Background="#3C3C3C"
                        BorderBrush="#555555" BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Margin="9,0,4,0"
                                   Foreground="#777777" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 TextChanged="SearchBox_TextChanged"
                                 Background="Transparent" Foreground="#CCCCCC"
                                 CaretBrush="#007ACC" BorderThickness="0"
                                 Padding="4,0" FontSize="12" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <Button Grid.Column="2" Content="📂  Open Folder"
                        Style="{StaticResource PrimaryBtn}" VerticalAlignment="Center"
                        x:Name="BtnOpen" Click="BtnOpen_Click"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════ BODY ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════ SIDEBAR ══ -->
            <Border Grid.Column="0" Background="#252526" BorderBrush="#3E3E3E" BorderThickness="0,0,1,0">
                <ScrollViewer Style="{StaticResource DarkScroll}" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,14,10,10">

                        <TextBlock Text="STATUS" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="2,0,0,8"/>

                        <RadioButton Style="{StaticResource FilterChip}" IsChecked="True" Click="FilterAll_Click">
                            <TextBlock Text="All Files" FontSize="12" Foreground="#CCCCCC"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" Click="FilterNew_Click">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#4EC9B0" Margin="0,0,8,0"/>
                                <TextBlock Text="New" FontSize="12" Foreground="#CCCCCC"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" Click="FilterModified_Click">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#DCDCAA" Margin="0,0,8,0"/>
                                <TextBlock Text="Modified" FontSize="12" Foreground="#CCCCCC"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" Click="FilterMissing_Click">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#F44747" Margin="0,0,8,0"/>
                                <TextBlock Text="Missing" FontSize="12" Foreground="#CCCCCC"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" Click="FilterApproved_Click">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#6A9955" Margin="0,0,8,0"/>
                                <TextBlock Text="Approved" FontSize="12" Foreground="#CCCCCC"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" Click="FilterRejected_Click">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#CE9178" Margin="0,0,8,0"/>
                                <TextBlock Text="Rejected" FontSize="12" Foreground="#CCCCCC"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource FilterChip}" Click="FilterDone_Click">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#C586C0" Margin="0,0,8,0"/>
                                <TextBlock Text="Done" FontSize="12" Foreground="#CCCCCC"/>
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="#3E3E3E" Margin="0,12,0,12"/>

                        <TextBlock Text="FILE TYPE" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="2,0,0,8"/>
                        <ComboBox x:Name="ExtFilter" Style="{StaticResource DarkCombo}"
                                  SelectionChanged="ExtFilter_SelectionChanged">
                            <ComboBoxItem Content="All types" IsSelected="True"/>
                            <ComboBoxItem Content=".mp4"/>
                            <ComboBoxItem Content=".mov"/>
                            <ComboBoxItem Content=".avi"/>
                            <ComboBoxItem Content=".mkv"/>
                            <ComboBoxItem Content=".mp3"/>
                            <ComboBoxItem Content=".wav"/>
                            <ComboBoxItem Content=".jpg"/>
                            <ComboBoxItem Content=".png"/>
                            <ComboBoxItem Content=".pdf"/>
                            <ComboBoxItem Content=".docx"/>
                        </ComboBox>

                        <Separator Background="#3E3E3E" Margin="0,12,0,12"/>

                        <TextBlock Text="RECENT FOLDERS" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="2,0,0,8"/>
                        <ItemsControl x:Name="RecentList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Tag="{Binding}"
                                            Click="RecentFolder_Click"
                                            Cursor="Hand" Focusable="False"
                                            Margin="0,0,0,2"
                                            ToolTip="{Binding}">
                                        <Button.ContextMenu>
                                            <ContextMenu Style="{StaticResource DarkMenu}">
                                                <MenuItem Header="Open in new window" Tag="{Binding}" Click="RecentFolder_NewWindow_Click"/>
                                                <MenuItem Header="Remove from list" Tag="{Binding}" Click="RecentFolder_Remove_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="Transparent"
                                                        CornerRadius="4" Padding="8,6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📁 " FontSize="11"/>
                                                        <TextBlock Text="{Binding}" Foreground="#AAAAAA"
                                                                   FontSize="11" TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="150"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#2D2D2D"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="#3E3E3E" Margin="0,12,0,12"/>

                        <TextBlock Text="STATISTICS" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="2,0,0,8"/>
                        <Border Background="#1E1E1E" CornerRadius="6" Padding="10,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,5"><TextBlock Text="Total"    Foreground="#777777" FontSize="11"/><TextBlock x:Name="StatsTotal"    Text="0" Foreground="#9CDCFE" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                                <Grid Margin="0,0,0,5"><TextBlock Text="New"      Foreground="#777777" FontSize="11"/><TextBlock x:Name="StatsNew"      Text="0" Foreground="#4EC9B0" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                                <Grid Margin="0,0,0,5"><TextBlock Text="Modified" Foreground="#777777" FontSize="11"/><TextBlock x:Name="StatsModified" Text="0" Foreground="#DCDCAA" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                                <Grid Margin="0,0,0,5"><TextBlock Text="Missing"  Foreground="#777777" FontSize="11"/><TextBlock x:Name="StatsMissing"  Text="0" Foreground="#F44747" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                                <Grid Margin="0,0,0,5"><TextBlock Text="Approved" Foreground="#777777" FontSize="11"/><TextBlock x:Name="StatsApproved" Text="0" Foreground="#6A9955" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                                <Grid>                 <TextBlock Text="Done"     Foreground="#777777" FontSize="11"/><TextBlock x:Name="StatsDone"     Text="0" Foreground="#C586C0" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ════════════ FILE LIST ══ -->
            <Grid Grid.Column="1" Background="#1E1E1E">

                <!-- File rows with resizable columns -->
                <ListView Grid.Row="0" Grid.RowSpan="2" x:Name="FileList"
                          Background="Transparent" BorderThickness="0"
                          ItemContainerStyle="{StaticResource FileRow}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          SelectionChanged="FileList_SelectionChanged"
                          MouseDoubleClick="FileList_DoubleClick"
                          AllowDrop="True" Drop="FileList_Drop"
                          DragOver="FileList_DragOver"
                          KeyDown="FileList_KeyDown"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListView.ContextMenu>
                        <ContextMenu Style="{StaticResource DarkMenu}">
                            <MenuItem Header="Open" Click="Ctx_Open"/>
                            <MenuItem Header="Rename  F2" Click="Ctx_Rename"/>
                            <Separator Background="#3E3E3E"/>
                            <MenuItem Header="Copy path" Click="Ctx_CopyPath"/>
                            <MenuItem Header="Show in Explorer" Click="Ctx_OpenInExplorer"/>
                            <Separator Background="#3E3E3E"/>
                            <MenuItem Header="Delete" Click="Ctx_Delete"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                    <ListView.Template>
                        <ControlTemplate TargetType="ListView">
                            <ScrollViewer Style="{StaticResource DarkScroll}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ListView.Template>
                    <ListView.View>
                        <GridView>
                            <GridView.ColumnHeaderContainerStyle>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Background" Value="#252526"/>
                                    <Setter Property="Foreground" Value="#666666"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderBrush" Value="#3E3E3E"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GridViewColumnHeader">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A2D2E"/>
                                                        <Setter Property="Foreground" Value="#CCCCCC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GridView.ColumnHeaderContainerStyle>

                            <!-- Icon -->
                            <GridViewColumn Width="30">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name, Converter={StaticResource ExtIcon}}"
                                                   FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Name — MaxWidth оновлюється з code-behind -->
                            <GridViewColumn Header="NAME" Width="300">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid x:Name="NameCell" VerticalAlignment="Center" Margin="0,2"
                                              MaxWidth="{Binding Path=Tag, RelativeSource={RelativeSource AncestorType=ListView}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding Name}"
                                                       Foreground="#CCCCCC" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       ToolTip="{Binding FullPath}"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding FullPath}"
                                                       Foreground="#555555" FontSize="10"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"/>
                                        </Grid>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Status -->
                            <GridViewColumn Header="STATUS" Width="95">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="3" Padding="7,2" HorizontalAlignment="Left" Margin="0,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2D2D2D"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="New">      <Setter Property="Background" Value="#1A3A35"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Modified"> <Setter Property="Background" Value="#3A3820"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Missing">  <Setter Property="Background" Value="#3A2020"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Approved"> <Setter Property="Background" Value="#1A2E1A"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Rejected"> <Setter Property="Background" Value="#3A2A20"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Done">     <Setter Property="Background" Value="#2A1A3A"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Locked">   <Setter Property="Background" Value="Transparent"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Status}"/>
                                                        <Setter Property="Foreground" Value="#888888"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Locked">   <Setter Property="Text" Value=""/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="New">      <Setter Property="Foreground" Value="#4EC9B0"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Modified"> <Setter Property="Foreground" Value="#DCDCAA"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Missing">  <Setter Property="Foreground" Value="#F44747"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Approved"> <Setter Property="Foreground" Value="#6A9955"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Rejected"> <Setter Property="Foreground" Value="#CE9178"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Done">     <Setter Property="Foreground" Value="#C586C0"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Size -->
                            <GridViewColumn Header="SIZE" Width="75">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SizeFormatted}" Foreground="#777777" FontSize="11" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>

                            <!-- Comment -->
                            <GridViewColumn Header="COMMENT" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Comment}" Foreground="#888888"
                                                   FontSize="11" FontStyle="Italic"
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <StackPanel>
                                                    <!-- Клікабельний заголовок групи -->
                                                    <ToggleButton x:Name="Tog" IsChecked="True"
                                                                  Cursor="Hand" Focusable="False"
                                                                  BorderThickness="0" Background="Transparent">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Border x:Name="Bd" Background="#252526" CornerRadius="4"
                                                                        Margin="2,8,8,1" Padding="10,6">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock x:Name="Arr" Text="▾  "
                                                                                   Foreground="#007ACC" FontSize="12"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   Foreground="#9CDCFE"
                                                                                   FontSize="12" FontWeight="SemiBold"
                                                                                   VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding ItemCount, StringFormat='  ({0})'}"
                                                                                   Foreground="#666666" FontSize="11"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsChecked" Value="False">
                                                                        <Setter TargetName="Arr" Property="Text" Value="▸  "/>
                                                                        <Setter TargetName="Bd" Property="Background" Value="#1E1E1E"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="#2A2D2E"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                    </ToggleButton>
                                                    <!-- Вміст групи -->
                                                    <ItemsPresenter x:Name="Items"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger SourceName="Tog" Property="IsChecked" Value="False">
                                                        <Setter TargetName="Items" Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="75"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="📄" FontSize="13" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding Name}" Foreground="#CCCCCC"
                                               FontSize="12" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullPath}"/>
                                    <TextBlock Text="{Binding FullPath}" Foreground="#555555"
                                               FontSize="10" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Border Grid.Column="2" VerticalAlignment="Center"
                                        CornerRadius="3" Padding="7,2" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2D2D2D"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="New">      <Setter Property="Background" Value="#1A3A35"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Modified"> <Setter Property="Background" Value="#3A3820"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Missing">  <Setter Property="Background" Value="#3A2020"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Approved"> <Setter Property="Background" Value="#1A2E1A"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Rejected"> <Setter Property="Background" Value="#3A2A20"/></DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Done">     <Setter Property="Background" Value="#2A1A3A"/></DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Status}"/>
                                                <Setter Property="Foreground" Value="#888888"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Locked">   <Setter Property="Text" Value=""/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="New">      <Setter Property="Foreground" Value="#4EC9B0"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Modified"> <Setter Property="Foreground" Value="#DCDCAA"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Missing">  <Setter Property="Foreground" Value="#F44747"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Approved"> <Setter Property="Foreground" Value="#6A9955"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Rejected"> <Setter Property="Foreground" Value="#CE9178"/></DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">     <Setter Property="Foreground" Value="#C586C0"/></DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <TextBlock Grid.Column="3" Text="{Binding SizeFormatted}"
                                           Foreground="#777777" FontSize="11" VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="4" Text="{Binding Comment}"
                                           Foreground="#888888" FontSize="11" FontStyle="Italic"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" Grid.Row="0"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            IsHitTestVisible="False">
                    <TextBlock Text="📁" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="No folder selected" Foreground="#007ACC"
                               FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click 'Open Folder' to load files"
                               Foreground="#555555" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ════════════ DETAIL PANEL ══ -->
            <Border Grid.Column="2" Background="#252526" BorderBrush="#3E3E3E" BorderThickness="1,0,0,0">
                <ScrollViewer Style="{StaticResource DarkScroll}" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="FILE DETAILS" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,4,0,10"/>

                        <Border Background="#1E1E1E" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock x:Name="DetailIcon" Text="📄" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DetailName" Text="Select a file" Foreground="#CCCCCC"
                                           FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                                           HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,3"/>
                                <TextBlock x:Name="DetailPath" Text="—" Foreground="#555555" FontSize="10"
                                           TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,6"><TextBlock Text="Size"   Foreground="#666666" FontSize="11"/><TextBlock x:Name="DetailSize"   Text="—" Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Right"/></Grid>
                                <Grid Margin="0,0,0,6"><TextBlock Text="Status" Foreground="#666666" FontSize="11"/><TextBlock x:Name="DetailStatus" Text="—" Foreground="#9CDCFE" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                                <Grid>                 <TextBlock Text="Folder" Foreground="#666666" FontSize="11"/><TextBlock x:Name="DetailFolder" Text="—" Foreground="#AAAAAA" FontSize="11" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" MaxWidth="110"/></Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="COMMENT" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="CommentBox" Style="{StaticResource DarkInput}"
                                 AcceptsReturn="True" Height="70" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,8"/>

                        <TextBlock Text="ACTIONS" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                        <UniformGrid Columns="2" Margin="0,0,0,4">
                            <Button Style="{StaticResource GhostBtn}" Margin="0,0,3,0" Click="BtnApprove_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✓ " Foreground="#6A9955"/>
                                    <TextBlock Text="Approve" Foreground="#CCCCCC"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostBtn}" Margin="3,0,0,0" Click="BtnReject_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✕ " Foreground="#F44747"/>
                                    <TextBlock Text="Reject" Foreground="#CCCCCC"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="0,0,0,4">
                            <Button Style="{StaticResource GhostBtn}" Margin="0,0,3,0" Click="BtnDone_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="★ " Foreground="#C586C0"/>
                                    <TextBlock Text="Done" Foreground="#CCCCCC"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GhostBtn}" Margin="3,0,0,0" Click="BtnSaveComment_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💾 " Foreground="#9CDCFE"/>
                                    <TextBlock Text="Save" Foreground="#CCCCCC"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>
                        <Button Style="{StaticResource DangerBtn}" Margin="0,4,0,0" Click="BtnDelete_Click">
                            <TextBlock Text="🗑  Delete File" Foreground="#FFFFFF"/>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ══════════════════════════════ STATUS BAR ══ -->
        <Border Grid.Row="2" Background="#007ACC">
            <Grid Margin="14,0">
                <ProgressBar x:Name="LoadingBar"
                             Visibility="Collapsed"
                             Minimum="0" Maximum="100" Value="0"
                             Width="120" Height="6"
                             Margin="0,0,12,0"
                             Background="#3E3E3E"
                             Foreground="#007ACC"
                             BorderThickness="0"/>
                <TextBlock x:Name="StatusBarText" Text="Ready — open a folder to start"
                           Foreground="#FFFFFF" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusBarCount" Text="0 files"
                           Foreground="#FFFFFF" FontSize="11"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
